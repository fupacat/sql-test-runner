{
  "name": "SQL Test Runner Dev Container",
  "dockerComposeFile": "docker-compose.yml",
  "service": "vscode",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-mssql.mssql",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "sqlTestRunner.connectionString": "Server=sqlserver,1433;Database=DevDb;User Id=sa;Password=${SA_PASSWORD:-YourStrong!Passw0rd};TrustServerCertificate=true",
        "sqlTestRunner.sqlcmdPath": "sqlcmd"
      }
    }
  },
  "postCreateCommand": "cd /workspace/extension && npm install",
  "remoteUser": "vscode"
}
